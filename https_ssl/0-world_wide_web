#!/bin/bash
# Usage: ./0-world_wide_web <domain> [subdomain]

domain=$1
subdomain=$2

# Function to query a subdomain and print info
get_record() {
    local full="$1.$domain"
    local record_type
    local destination

    # Use dig to get the record type and IP
    # Filter ANSWER SECTION using awk
    read record_type destination <<< $(dig $full | awk '/ANSWER SECTION:/ {getline; print $4, $5}')
    
    echo "The subdomain $1 is a $record_type record and points to $destination"
}

# If subdomain is provided, show only that
if [ -n "$subdomain" ]; then
    get_record $subdomain
else
    # Default order
    for sd in www lb-01 web-01 web-02; do
        get_record $sd
    done
fi
